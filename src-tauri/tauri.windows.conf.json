{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "targets": ["msi", "nsis"],
    "windows": {
      "allowDowngrades": false,
      "wix": {
        "language": ["en-US", "de-DE"]
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "languages": ["English", "German"],
        "displayLanguageSelector": true,
        "startMenuFolder": "VaultGuard",
        "compression": "lzma"
      }
    }
  }
}
